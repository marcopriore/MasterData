# MasterData API - Variáveis de ambiente
# Copie para .env e ajuste os valores

# CORS (opcional): lista separada por vírgula, ou * para liberar todas (sem credentials)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL do banco de dados (obrigatório)
# PostgreSQL: postgresql+psycopg://user:password@host:port/dbname
# SQLite:    sqlite:///./masterdata.db
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/masterdata

# SMTP (opcional - notificações por e-mail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@masterdata.local
